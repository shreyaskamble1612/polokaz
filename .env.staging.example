# =============================================================================
# STAGING ENVIRONMENT
# =============================================================================

NEXT_PUBLIC_APP_URL=https://staging.polokaz.com
NEXT_PUBLIC_API_URL=https://api-staging.polokaz.com

DATABASE_URL=postgresql://user:password@staging-db-host:5432/polokaz_staging

BETTER_AUTH_SECRET=staging-secret-min-32-chars-change-this

PORT=3001
NODE_ENV=staging

# Stripe test mode (use test keys in staging)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GOLD_MONTHLY=price_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_MERCHANT_MONTHLY=price_...
STRIPE_PRICE_REGULAR_MONTHLY=price_...
STRIPE_PRICE_REGULAR_YEARLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...
STRIPE_PRICE_ORGANIZATION_MONTHLY=price_...
STRIPE_PRICE_ORGANIZATION_YEARLY=price_...
STRIPE_PRICE_SMALL_VENDOR_MONTHLY=price_...
STRIPE_PRICE_SMALL_VENDOR_YEARLY=price_...
STRIPE_PRICE_PREMIUM_VENDOR_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_VENDOR_YEARLY=price_...
STRIPE_CHECKOUT_SUCCESS_URL=https://staging.polokaz.com/dashboard?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://staging.polokaz.com/pricing

# Coupontools staging
COUPONTOOLS_API_KEY=
COUPONTOOLS_API_SECRET=
COUPONTOOLS_BASE_URL=https://api.coupontools.com/v1
COUPONTOOLS_WEBHOOK_SECRET=

# Trackdesk staging
TRACKDESK_API_KEY=
TRACKDESK_CAMPAIGN_ID=
TRACKDESK_BASE_URL=https://api.trackdesk.com/v1
TRACKDESK_WEBHOOK_SECRET=

LOG_LEVEL=info

# Sentry for error tracking
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.5

# Email service
RESEND_API_KEY=
SMTP_FROM=staging@polokaz.com

# Redis
REDIS_URL=redis://staging-redis:6379

# Feature flags
ENABLE_REFERRAL_REWARDS=true
ENABLE_SUBSCRIPTION_TRIALS=true
ENABLE_AFFILIATE_TRACKING=true
ENABLE_WEBHOOK_RETRY=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

CORS_ORIGINS=https://staging.polokaz.com

DEBUG=false
