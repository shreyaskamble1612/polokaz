# =============================================================================
# PRODUCTION ENVIRONMENT
# =============================================================================

NEXT_PUBLIC_APP_URL=https://polokaz.com
NEXT_PUBLIC_API_URL=https://api.polokaz.com

DATABASE_URL=postgresql://user:password@prod-db-host:5432/polokaz_production

BETTER_AUTH_SECRET=production-secret-min-32-chars-CHANGE-THIS

PORT=3001
NODE_ENV=production

# Stripe LIVE mode (use live keys in production)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GOLD_MONTHLY=price_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_MERCHANT_MONTHLY=price_...
STRIPE_CHECKOUT_SUCCESS_URL=https://polokaz.com/dashboard?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://polokaz.com/pricing

# Coupontools production
COUPONTOOLS_API_KEY=
COUPONTOOLS_API_SECRET=
COUPONTOOLS_BASE_URL=https://api.coupontools.com/v1
COUPONTOOLS_WEBHOOK_SECRET=

# Trackdesk production
TRACKDESK_API_KEY=
TRACKDESK_CAMPAIGN_ID=
TRACKDESK_BASE_URL=https://api.trackdesk.com/v1
TRACKDESK_WEBHOOK_SECRET=

LOG_LEVEL=warn

# Sentry for error tracking
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email service
RESEND_API_KEY=
SMTP_FROM=noreply@polokaz.com

# Redis
REDIS_URL=redis://prod-redis:6379

# Feature flags
ENABLE_REFERRAL_REWARDS=true
ENABLE_SUBSCRIPTION_TRIALS=true
ENABLE_AFFILIATE_TRACKING=true
ENABLE_WEBHOOK_RETRY=true

# Rate limiting (stricter in production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

CORS_ORIGINS=https://polokaz.com

# Analytics
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=
POSTHOG_API_KEY=

# Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=polokaz-production-assets

DEBUG=false
